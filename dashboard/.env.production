# Production runs in snapshot mode: the dashboard renders from the static
# data snapshot bundled with the build (public/snapshot/*), so the demo never
# depends on a backend being up. To layer a live API back on top, set
# VITE_API_URL to its origin (e.g. in the Vercel project env settings, which
# take precedence over this file at build time). The app then tries the API
# with a 4s timeout and falls back to the snapshot with a "cached data" badge.
VITE_API_URL=
